# FastAPI
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:3000
REPOSITORY_WORKSPACE_TTL_SECONDS=3600
REPOSITORY_MAX_DOWNLOAD_BYTES=52428800
REPOSITORY_MAX_EXPANDED_BYTES=104857600
REPOSITORY_MAX_FILES=5000
REPOSITORY_CLONE_TIMEOUT_SECONDS=120
REPOSITORY_MAX_SOURCE_FILE_BYTES=524288
# Leave empty to use an operating-system temporary directory.
REPOSITORY_TEMP_ROOT=

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
